{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dg-anvil/schemas/plan-schema.json",
  "title": "Anvil Plan",
  "type": "object",
  "required": ["anvil_plan_version", "tasks"],
  "additionalProperties": false,
  "properties": {
    "anvil_plan_version": { "type": "integer", "const": 1 },
    "contract_ref": { "type": "string" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "wave", "criterion_ids"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^T[0-9]+$" },
          "wave": { "type": "integer", "minimum": 0 },
          "title": { "type": "string", "minLength": 1 },
          "criterion_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "loop_cap": { "type": "integer", "minimum": 1 },
          "summary": { "type": "string" },
          "scope_paths": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
